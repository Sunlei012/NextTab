{
  "manifest_version": 3,
  "name": "TabNexus",
  "version": "1.0",
  "description": "Smart Tab Hub that categorizes your open tabs using Gemini AI.",
  "permissions": ["tabs"],
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
